# ─────────────────────────────────────────────────────────────────────────────
# TradingBot — Environment Variables
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#
# Generate SECRET_KEY:  python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────

# Flask session secret — change this to a random 32+ character string
SECRET_KEY=change-me-run-make-secret-to-generate


# ─── Bot credentials ──────────────────────────────────────────────────────────
# Each bot has its own dedicated OANDA sub-account (or Kraken account for crypto).
# Naming convention:  JAMIE_<BOT>_ACCOUNT_ID / JAMIE_<BOT>_ACCESS_TOKEN / JAMIE_<BOT>_ACCOUNT_TYPE
# Account types:  practice | live | kraken_futures | kraken_futures_demo

# Stat-Arb bot (pairs trading — EUR/USD vs GBP/USD, NAS100 vs SPX500)
JAMIE_STAT_ARB_ACCOUNT_ID=101-002-XXXXXXXX-003
JAMIE_STAT_ARB_ACCESS_TOKEN=your-oanda-access-token
JAMIE_STAT_ARB_ACCOUNT_TYPE=practice

# Momentum bot (H1 trend-following on SPX500 / NAS100 / XAU)
JAMIE_MOMENTUM_ACCOUNT_ID=101-002-XXXXXXXX-005
JAMIE_MOMENTUM_ACCESS_TOKEN=your-oanda-access-token
JAMIE_MOMENTUM_ACCOUNT_TYPE=practice

# Vol-Premium bot (sells volatility when IV > RV)
JAMIE_VOL_PREMIUM_ACCOUNT_ID=101-002-XXXXXXXX-004
JAMIE_VOL_PREMIUM_ACCESS_TOKEN=your-oanda-access-token
JAMIE_VOL_PREMIUM_ACCOUNT_TYPE=practice

# Crypto bot (M15 RSI momentum on BTC/ETH/SOL via Kraken Futures)
# Account ID = Kraken API Public Key
# Access Token = Kraken API Private Key
JAMIE_CRYPTO_ACCOUNT_ID=your-kraken-public-key
JAMIE_CRYPTO_ACCESS_TOKEN=your-kraken-private-key
JAMIE_CRYPTO_ACCOUNT_TYPE=kraken_futures

# Daily-Target bot (2% daily P&L target on major FX + indices)
JAMIE_DAILY_TARGET_ACCOUNT_ID=101-002-XXXXXXXX-002
JAMIE_DAILY_TARGET_ACCESS_TOKEN=your-oanda-access-token
JAMIE_DAILY_TARGET_ACCOUNT_TYPE=practice

# Scalp bot (high-leverage M5 EMA scalper — ~$200 dedicated account)
JAMIE_SCALP_ACCOUNT_ID=101-002-XXXXXXXX-006
JAMIE_SCALP_ACCESS_TOKEN=your-oanda-access-token
JAMIE_SCALP_ACCOUNT_TYPE=practice


# ─── Optional ─────────────────────────────────────────────────────────────────
# Fallback OANDA credentials used only for price feeds when a bot's account
# hasn't been configured yet.
OANDA_ACCOUNT_ID=101-002-XXXXXXXX-001
OANDA_ACCESS_TOKEN=your-oanda-access-token
OANDA_ACCOUNT_TYPE=practice

# PORT is set automatically by Railway — leave commented out for local dev
# PORT=8080
