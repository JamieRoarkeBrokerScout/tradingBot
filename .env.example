# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Optional: fallback OANDA credentials (users can also save their own via Settings)
OANDA_ACCOUNT_ID=your-account-id
OANDA_ACCESS_TOKEN=your-access-token
OANDA_ACCOUNT_TYPE=practice

# PORT is set automatically by Railway — do not set this manually
# PORT=8080
